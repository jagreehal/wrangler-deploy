{
  "name": "{{projectName}}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,worker -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "cd workers/api && wrangler dev --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "wd": "wd",
    "plan": "wd plan --stage staging",
    "apply": "wd apply --stage staging",
    "deploy": "wd deploy --stage staging"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wrangler": "^4.80.0",
    "wrangler-deploy": "^1.4.0"
  }
}
