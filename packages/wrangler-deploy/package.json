{
  "name": "wrangler-deploy",
  "version": "1.4.0",
  "description": "Create, deploy, and tear down full Cloudflare Workers environments per stage",
  "type": "module",
  "bin": {
    "wrangler-deploy": "./dist/cli/index.js",
    "wd": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate:agent-context": "node scripts/generate-agent-context.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.build.json --watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "wrangler": ">=4.80.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "usage-guard-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "executable-stories-vitest": "^8.1.9",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "guard",
    "README.md",
    "github",
    "agent-context.json"
  ],
  "keywords": [
    "cloudflare",
    "workers",
    "wrangler",
    "staging",
    "preview",
    "environment",
    "infrastructure",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/wrangler-deploy"
  },
  "license": "MIT"
}
