{
  "name": "workers-usage-guard",
  "version": "0.1.0",
  "description": "Cloudflare Workers kill-switch — auto-disable Workers when usage crosses thresholds. Ships with the `wug` CLI for one-command setup.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/wrangler-deploy",
    "directory": "packages/workers-usage-guard"
  },
  "homepage": "https://github.com/jagreehal/wrangler-deploy/tree/main/packages/workers-usage-guard",
  "bugs": {
    "url": "https://github.com/jagreehal/wrangler-deploy/issues"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "monitoring",
    "workflows",
    "usage",
    "guardrail"
  ],
  "type": "module",
  "bin": {
    "wug": "./dist/cli/index.js",
    "workers-usage-guard": "./dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "wrangler.jsonc",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "workers-usage-guard-shared": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bundle": "wrangler deploy --dry-run --outdir dist-bundle",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:int": "vitest run --config vitest.int.config.ts",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "prepublishOnly": "pnpm check",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^25.6.2",
    "miniflare": "^4.20260507.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^3.0.0",
    "wrangler": "^4.90.0"
  }
}
