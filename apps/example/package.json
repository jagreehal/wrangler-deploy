{
  "name": "example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,batch,events -c blue,magenta,cyan \"pnpm dev:api\" \"pnpm dev:batch\" \"pnpm dev:events\"",
    "dev:api": "cd workers/api && wrangler dev --port 8787",
    "dev:batch": "cd workers/batch-workflow && wrangler dev --port 8789",
    "dev:events": "cd workers/event-router && wrangler dev --port 8788",
    "dev:cron": "tsx scripts/dev-cron.ts",
    "stage:dev": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts dev",
    "stage:dev:workers": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts dev --port 8787",
    "stage:dev:session": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts dev --session --persist-to .wrangler/state",
    "stage:dev:doctor": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts dev doctor",
    "stage:dev:ui": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts dev ui --port 8899",
    "stage:verify:local": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts verify local",
    "stage:verify:smoke": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts verify local --pack smoke",
    "stage:verify:regression": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts verify local --pack regression",
    "stage:fixture:list": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts fixture list",
    "stage:snapshot:list": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts snapshot list",
    "stage:snapshot:save": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts snapshot save local-baseline",
    "stage:snapshot:load": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts snapshot load local-baseline",
    "stage:cron": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts cron trigger workers/batch-workflow --port 8787",
    "stage:logs": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts logs workers/api --once",
    "stage:worker:routes": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts worker routes workers/api",
    "stage:queues": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts queue list",
    "stage:queue:send": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts queue send payment-outbox --json '{\"type\":\"batch.dispatched\",\"data\":{\"batchId\":\"local-test\"}}'",
    "stage:queue:send:fixture": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts queue send --fixture payment-outbox-dispatch",
    "stage:queue:watch": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts queue send payment-outbox --json '{\"type\":\"batch.dispatched\",\"data\":{\"batchId\":\"watch-test\"}}' --watch --count 2 --every 1s",
    "stage:queue:replay": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts queue replay payment-outbox --file fixtures/payment-outbox.json",
    "stage:queue:tail": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts queue tail payment-outbox --once",
    "stage:d1:list": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts d1 list",
    "stage:d1:inspect": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts d1 inspect payments-db",
    "stage:d1:exec": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts d1 exec payments-db --sql 'SELECT COUNT(*) AS batch_count FROM batches;'",
    "stage:d1:exec:fixture": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts d1 exec --fixture payments-batch-count",
    "stage:d1:seed": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts d1 seed payments-db",
    "stage:d1:reset": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts d1 reset payments-db",
    "stage:worker:call": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts worker call workers/api --method POST --path /__wd/echo --query source=stage-worker-call --header x-request-id=local-worker-call --json '{\"ping\":true}'",
    "stage:worker:call:endpoint": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts worker call workers/api --endpoint echo --query source=endpoint-call --header x-request-id=endpoint-call --json '{\"ping\":true}'",
    "stage:worker:call:fixture": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts worker call --fixture echo-ping",
    "stage:plan": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts plan",
    "stage:apply": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts apply",
    "stage:deploy": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts deploy",
    "stage:destroy": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts destroy",
    "stage:status": "npx tsx ../../packages/wrangler-deploy/src/cli/index.ts status",
    "db:init": "wrangler d1 execute payments-db --local --file=sql/init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/node": "^25.5.2",
    "wrangler-deploy": "workspace:*",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "hono": "^4.12.14"
  }
}
