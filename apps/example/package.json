{
  "name": "example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wd dev",
    "dev:session": "wd dev --session --persist-to .wrangler/state",
    "dev:doctor": "wd dev doctor",
    "dev:ui": "wd dev ui --port 8899",
    "dev:cron": "tsx scripts/dev-cron.ts",
    "verify:local": "wd verify local",
    "verify:smoke": "wd verify local --pack smoke",
    "verify:regression": "wd verify local --pack regression",
    "dev:fixture:list": "wd fixture list",
    "dev:snapshot:list": "wd snapshot list",
    "dev:snapshot:save": "wd snapshot save local-baseline",
    "dev:snapshot:load": "wd snapshot load local-baseline",
    "cron:trigger": "wd cron trigger workers/batch-workflow",
    "logs": "wd logs workers/api --once",
    "worker:routes": "wd worker routes workers/api",
    "queue:list": "wd queue list",
    "queue:send": "wd queue send payment-outbox --json '{\"type\":\"batch.dispatched\",\"data\":{\"batchId\":\"local-test\"}}'",
    "queue:replay": "wd queue replay payment-outbox --file fixtures/payment-outbox.json",
    "queue:tail": "wd queue tail payment-outbox --once",
    "d1:list": "wd d1 list",
    "d1:inspect": "wd d1 inspect payments-db",
    "d1:exec": "wd d1 exec payments-db --sql 'SELECT COUNT(*) AS batch_count FROM batches;'",
    "d1:seed": "wd d1 seed payments-db",
    "d1:reset": "wd d1 reset payments-db",
    "worker:call": "wd worker call workers/api --method POST --path /__wd/echo --query source=stage-worker-call --header x-request-id=local-worker-call",
    "plan": "wd plan",
    "apply": "wd apply",
    "deploy": "wd deploy",
    "destroy": "wd destroy",
    "status": "wd status",
    "open": "wd open",
    "dashboard": "wd dashboard",
    "db:init": "wrangler d1 execute payments-db --local --file=sql/init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260510.1",
    "@types/node": "^25.6.2",
    "wrangler-deploy": "workspace:*",
    "tsx": "^4.21.0",
    "wrangler": "^4.92.0"
  }
}
